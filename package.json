{
  "name": "lhasa-ligand-builder",
  "description": "Moorhen's ligand builder: React + WebAssembly version of Layla - Coot's ligand builder",
  "version": "0.4.3",
  "type": "module",
  "main": "dist/lhasa-ligand-builder.js",
  "module": "dist/lhasa-ligand-builder.js",
  "types": "dist/src/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lhasa-ligand-builder.js",
      "types": "./dist/src/lib.d.ts"
    },
    "./style.css": "./dist/lhasa-ligand-builder.css",
    "./lhasa-vite-plugin": "./bundler_plugins/vite.mjs",
    "./lhasa-webpack-plugin": "./bundler_plugins/webpack.cjs"
  },
  "files": [
    "dist",
    "bundler_plugins"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite serve",
    "build": "tsc && vite build",
    "build:lib": "node scripts/build-lib.mjs",
    "prepublishOnly": "npm run build:lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "d3": "^7.9.0",
    "react-hotkeys": "^2.0.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.83.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.6",
    "vite-plugin-cross-origin-isolation": "^0.1.6",
    "vite-plugin-dts": "^4.5.0"
  }
}
